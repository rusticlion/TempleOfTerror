# yaml-language-server: $schema=../../Schemas/archetypes.schema.json
- id: explorer
  name: Explorer
  description: Leads the way into unstable places and keeps the expedition moving.
  defaultActions:
    Survey: 2
    Prowl: 1
    Finesse: 1
- id: scout
  name: Scout
  description: Reads danger early and finds the path nobody else spots in time.
  defaultActions:
    Hunt: 2
    Survey: 1
    Prowl: 1
- id: scholar
  name: Scholar
  description: Deciphers warnings, rituals, and the systems holding the place together.
  defaultActions:
    Study: 2
    Tinker: 1
    Attune: 1
