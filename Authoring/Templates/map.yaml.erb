# yaml-language-server: $schema=../../Schemas/map.schema.json
startingNode: <%= starting_node_id %>
nodes:
  <%= starting_node_id %>:
    name: <%= starting_node_name %>
    soundProfile: cave_drips
    theme: approach
    isDiscovered: true
    interactables:
      - id: <%= scenario_id %>_break_camp
        title: Break Camp
        description: You can call the expedition off before it becomes a disaster.
        availableActions:
          - name: Leave while you can
            actionType: Consort
            position: controlled
            effect: standard
            requiresTest: false
            outcomes:
              success:
                - type: endRun
                  runOutcome: escaped
                  runOutcomeText: You leave with your people alive and your ambition deferred.
    connections: []
